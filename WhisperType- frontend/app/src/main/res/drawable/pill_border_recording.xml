<?xml version="1.0" encoding="utf-8"?>
<!--
Liquid Glass Pill - Recording State Border
Warm coral glow with layered diffusion for active recording
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Layer 5: Outermost soft ambient glow -->
    <item
        android:top="-12dp"
        android:bottom="-12dp"
        android:left="-12dp"
        android:right="-12dp">
        <shape android:shape="rectangle">
            <solid android:color="#28d4845a" />
            <corners android:radius="38dp" />
        </shape>
    </item>

    <!-- Layer 4: Mid glow - builds warmth -->
    <item
        android:top="-7dp"
        android:bottom="-7dp"
        android:left="-7dp"
        android:right="-7dp">
        <shape android:shape="rectangle">
            <solid android:color="#45d4845a" />
            <corners android:radius="33dp" />
        </shape>
    </item>

    <!-- Layer 3: Inner glow - bright edge -->
    <item
        android:top="-3dp"
        android:bottom="-3dp"
        android:left="-3dp"
        android:right="-3dp">
        <shape android:shape="rectangle">
            <solid android:color="#60d4845a" />
            <corners android:radius="29dp" />
        </shape>
    </item>

    <!-- Layer 2: Crisp bright border -->
    <item>
        <shape android:shape="rectangle">
            <stroke
                android:width="1.5dp"
                android:color="#AAd4845a" />
            <corners android:radius="26dp" />
            <solid android:color="#00000000" />
        </shape>
    </item>

    <!-- Layer 1: Main glass fill -->
    <item
        android:top="1.5dp"
        android:bottom="1.5dp"
        android:left="1.5dp"
        android:right="1.5dp">
        <shape android:shape="rectangle">
            <solid android:color="#B31A1F2E" />
            <corners android:radius="24dp" />
        </shape>
    </item>

    <!-- Layer 0: Inner warm highlight -->
    <item
        android:top="1.5dp"
        android:bottom="1.5dp"
        android:left="1.5dp"
        android:right="1.5dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:startColor="#12d4845a"
                android:centerColor="#06FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="90" />
            <corners android:radius="24dp" />
        </shape>
    </item>

</layer-list>
