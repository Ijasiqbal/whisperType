<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib"
                    xmlns:converters="clr-namespace:Vozcribe.Converters">

    <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
    <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
    <converters:AmpToHeightConverter x:Key="AmpToHeight"/>

    <!-- ═══════════════════════════════════════════════════════════════
         STUDIO CONSOLE — design tokens
         ═══════════════════════════════════════════════════════════════ -->

    <!-- Surface -->
    <Color x:Key="CanvasColor">#FF0B0B0F</Color>
    <Color x:Key="PanelColor">#FF14141A</Color>
    <Color x:Key="PanelRaisedColor">#FF1C1C24</Color>
    <Color x:Key="EdgeColor">#FF2A2A34</Color>
    <Color x:Key="EdgeSoftColor">#FF1F1F28</Color>

    <SolidColorBrush x:Key="CanvasBrush" Color="{StaticResource CanvasColor}"/>
    <SolidColorBrush x:Key="PanelBrush" Color="{StaticResource PanelColor}"/>
    <SolidColorBrush x:Key="PanelRaisedBrush" Color="{StaticResource PanelRaisedColor}"/>
    <SolidColorBrush x:Key="EdgeBrush" Color="{StaticResource EdgeColor}"/>
    <SolidColorBrush x:Key="EdgeSoftBrush" Color="{StaticResource EdgeSoftColor}"/>

    <!-- Type -->
    <SolidColorBrush x:Key="InkBrush" Color="#FFF2EEE5"/>
    <SolidColorBrush x:Key="InkMutedBrush" Color="#FFA8A096"/>
    <SolidColorBrush x:Key="InkDimBrush" Color="#FF6E6A61"/>

    <!-- Signal (accents) -->
    <SolidColorBrush x:Key="AmberBrush" Color="#FFFFB547"/>
    <SolidColorBrush x:Key="AmberGlowBrush" Color="#55FFB547"/>
    <SolidColorBrush x:Key="TealBrush" Color="#FF4FB8A8"/>
    <SolidColorBrush x:Key="RedBrush" Color="#FFE05D5D"/>

    <!-- Fonts: distinctive built-ins, no embedding -->
    <FontFamily x:Key="DisplayFont">Sitka Banner, Cambria, Georgia, serif</FontFamily>
    <FontFamily x:Key="BodyFont">Segoe UI Variable Text, Segoe UI, sans-serif</FontFamily>
    <FontFamily x:Key="MonoFont">JetBrains Mono, Consolas, Courier New, monospace</FontFamily>

    <!-- Corner rounding — soft, not pill-ish -->
    <CornerRadius x:Key="RadiusSm">4</CornerRadius>
    <CornerRadius x:Key="RadiusMd">8</CornerRadius>
    <CornerRadius x:Key="RadiusLg">14</CornerRadius>

    <!-- ═══════════════════════════════════════════════════════════════
         TYPOGRAPHY STYLES
         ═══════════════════════════════════════════════════════════════ -->

    <Style x:Key="DisplayHeading" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource DisplayFont}"/>
        <Setter Property="FontStyle" Value="Italic"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="FontSize" Value="42"/>
        <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
        <Setter Property="LineHeight" Value="46"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
    </Style>

    <Style x:Key="SectionLabel" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource DisplayFont}"/>
        <Setter Property="FontStyle" Value="Italic"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="Foreground" Value="{StaticResource InkMutedBrush}"/>
    </Style>

    <Style x:Key="EyebrowLabel" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Foreground" Value="{StaticResource InkDimBrush}"/>
        <Setter Property="Typography.Capitals" Value="AllSmallCaps"/>
    </Style>

    <Style x:Key="BodyText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
    </Style>

    <Style x:Key="MutedText" TargetType="TextBlock" BasedOn="{StaticResource BodyText}">
        <Setter Property="Foreground" Value="{StaticResource InkMutedBrush}"/>
    </Style>

    <Style x:Key="MonoCaption" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="{StaticResource InkMutedBrush}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         BUTTONS
         ═══════════════════════════════════════════════════════════════ -->

    <!-- Ghost (default) — subtle outline, hover fills -->
    <Style x:Key="GhostButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource EdgeBrush}"/>
        <Setter Property="Padding" Value="14,7"/>
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource RadiusMd}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          TextBlock.Foreground="{TemplateBinding Foreground}"
                                          TextBlock.FontFamily="{TemplateBinding FontFamily}"
                                          TextBlock.FontSize="{TemplateBinding FontSize}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource PanelRaisedBrush}"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource InkDimBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource PanelBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Legacy alias — existing code references OverlayButton -->
    <Style x:Key="OverlayButton" TargetType="Button" BasedOn="{StaticResource GhostButton}"/>

    <!-- Primary — amber fill for "go" actions -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource AmberBrush}"/>
        <Setter Property="Foreground" Value="#FF0B0B0F"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="20,10"/>
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root" Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource RadiusMd}"
                            Padding="{TemplateBinding Padding}">
                        <Border.Effect>
                            <DropShadowEffect Color="#FFB547" BlurRadius="18" Opacity="0.25" ShadowDepth="0"/>
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          TextBlock.Foreground="{TemplateBinding Foreground}"
                                          TextBlock.FontFamily="{TemplateBinding FontFamily}"
                                          TextBlock.FontSize="{TemplateBinding FontSize}"
                                          TextBlock.FontWeight="{TemplateBinding FontWeight}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#FFFFC46B"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#FFE69F2F"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Close icon — small round X for dismissing overlays -->
    <Style x:Key="CloseIconButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Width" Value="20"/>
        <Setter Property="Height" Value="20"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root" Background="{TemplateBinding Background}"
                            CornerRadius="10">
                        <Path x:Name="Icon" Data="M 5 5 L 11 11 M 11 5 L 5 11"
                              Stroke="{StaticResource InkMutedBrush}"
                              StrokeThickness="1.5"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource PanelRaisedBrush}"/>
                            <Setter TargetName="Icon" Property="Stroke" Value="{StaticResource InkBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Quiet — text-only link-ish -->
    <Style x:Key="QuietButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource InkMutedBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          TextBlock.Foreground="{TemplateBinding Foreground}"
                                          TextBlock.FontFamily="{TemplateBinding FontFamily}"
                                          TextBlock.FontSize="{TemplateBinding FontSize}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         COMBOBOX — custom chrome, no WPF defaults
         ═══════════════════════════════════════════════════════════════ -->

    <Style x:Key="StudioComboToggle" TargetType="ToggleButton">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="Root" Background="{StaticResource PanelRaisedBrush}"
                            BorderBrush="{StaticResource EdgeBrush}" BorderThickness="1"
                            CornerRadius="{StaticResource RadiusMd}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ContentPresenter Grid.Column="0" Margin="12,8,4,8"
                                              HorizontalAlignment="Left" VerticalAlignment="Center"/>
                            <Path Grid.Column="1" Margin="10,0,12,0" VerticalAlignment="Center"
                                  Data="M 0 0 L 4 4 L 8 0" Stroke="{StaticResource InkMutedBrush}"
                                  StrokeThickness="1.4" StrokeLineJoin="Round"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource InkDimBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="StudioComboBox" TargetType="ComboBox">
        <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
        <Setter Property="Background" Value="{StaticResource PanelRaisedBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource EdgeBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton Name="ToggleButton" Style="{StaticResource StudioComboToggle}"
                                      Focusable="False"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                      ClickMode="Press">
                            <ContentPresenter Name="ContentSite"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              IsHitTestVisible="False"
                                              TextBlock.Foreground="{StaticResource InkBrush}"
                                              TextBlock.FontFamily="{StaticResource BodyFont}"
                                              TextBlock.FontSize="13"/>
                        </ToggleButton>
                        <Popup Name="Popup" Placement="Bottom" AllowsTransparency="True"
                               IsOpen="{TemplateBinding IsDropDownOpen}" Focusable="False"
                               PopupAnimation="Fade">
                            <Border x:Name="DropDown" MinWidth="{TemplateBinding ActualWidth}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                    Background="{StaticResource PanelRaisedBrush}"
                                    BorderBrush="{StaticResource EdgeBrush}" BorderThickness="1"
                                    CornerRadius="{StaticResource RadiusMd}" Margin="0,4,0,0">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="24" Opacity="0.5" ShadowDepth="6" Color="Black"/>
                                </Border.Effect>
                                <ScrollViewer Margin="4" SnapsToDevicePixels="True">
                                    <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Padding" Value="10,7"/>
                    <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
                    <Setter Property="FontFamily" Value="{StaticResource BodyFont}"/>
                    <Setter Property="FontSize" Value="13"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ComboBoxItem">
                                <Border x:Name="Root" Background="Transparent"
                                        CornerRadius="{StaticResource RadiusSm}"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter TextBlock.Foreground="{TemplateBinding Foreground}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter TargetName="Root" Property="Background" Value="{StaticResource EdgeBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource AmberBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         CHECKBOX
         ═══════════════════════════════════════════════════════════════ -->

    <Style x:Key="StudioCheckBox" TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal">
                        <Border x:Name="Box" Width="16" Height="16" VerticalAlignment="Center"
                                Background="{StaticResource PanelRaisedBrush}"
                                BorderBrush="{StaticResource EdgeBrush}" BorderThickness="1"
                                CornerRadius="3">
                            <Path x:Name="Check" Data="M 2.5 6 L 6 9.5 L 12 3"
                                  Stroke="{StaticResource AmberBrush}" StrokeThickness="1.8"
                                  StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Opacity="0"/>
                        </Border>
                        <ContentPresenter Margin="10,0,0,0" VerticalAlignment="Center"
                                          TextBlock.Foreground="{TemplateBinding Foreground}"
                                          TextBlock.FontFamily="{TemplateBinding FontFamily}"
                                          TextBlock.FontSize="{TemplateBinding FontSize}"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Check" Property="Opacity" Value="1"/>
                            <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource AmberBrush}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource InkDimBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         RADIOBUTTON
         ═══════════════════════════════════════════════════════════════ -->

    <Style x:Key="StudioRadioButton" TargetType="RadioButton">
        <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <StackPanel Orientation="Horizontal">
                        <Grid Width="16" Height="16" VerticalAlignment="Center">
                            <Ellipse x:Name="Ring" Stroke="{StaticResource EdgeBrush}" StrokeThickness="1"
                                     Fill="{StaticResource PanelRaisedBrush}"/>
                            <Ellipse x:Name="Dot" Width="7" Height="7" Fill="{StaticResource AmberBrush}"
                                     Opacity="0"/>
                        </Grid>
                        <ContentPresenter Margin="10,0,0,0" VerticalAlignment="Center"
                                          TextBlock.Foreground="{TemplateBinding Foreground}"
                                          TextBlock.FontFamily="{TemplateBinding FontFamily}"
                                          TextBlock.FontSize="{TemplateBinding FontSize}"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Dot" Property="Opacity" Value="1"/>
                            <Setter TargetName="Ring" Property="Stroke" Value="{StaticResource AmberBrush}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Ring" Property="Stroke" Value="{StaticResource InkDimBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         PROGRESSBAR (mixer-style segmented fill)
         ═══════════════════════════════════════════════════════════════ -->

    <Style x:Key="StudioProgressBar" TargetType="ProgressBar">
        <Setter Property="Height" Value="4"/>
        <Setter Property="Background" Value="{StaticResource EdgeBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource AmberBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Border Background="{TemplateBinding Background}" CornerRadius="2">
                        <Grid ClipToBounds="True">
                            <Rectangle Name="PART_Track"/>
                            <Rectangle Name="PART_Indicator" HorizontalAlignment="Left"
                                       Fill="{TemplateBinding Foreground}" RadiusX="2" RadiusY="2"/>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         SCROLLBAR (thin, dark)
         ═══════════════════════════════════════════════════════════════ -->

    <Style x:Key="StudioScrollThumb" TargetType="Thumb">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border Background="{StaticResource EdgeBrush}" CornerRadius="3" Margin="2,0"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="StudioScrollBar" TargetType="ScrollBar">
        <Setter Property="Width" Value="8"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="Transparent">
                        <Track Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb Style="{StaticResource StudioScrollThumb}"/>
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0"/>
                            </Track.IncreaseRepeatButton>
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0"/>
                            </Track.DecreaseRepeatButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         KEYCAP — visual hotkey tokens (e.g., ⌃ Space)
         ═══════════════════════════════════════════════════════════════ -->

    <Style x:Key="Keycap" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource PanelRaisedBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource EdgeBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="7,3"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         WINDOW CHROME — soft radial backdrop
         ═══════════════════════════════════════════════════════════════ -->

    <RadialGradientBrush x:Key="CanvasGlow" GradientOrigin="0.5,0.05" Center="0.5,0.05"
                         RadiusX="0.9" RadiusY="0.7">
        <GradientStop Color="#FF1A1520" Offset="0.0"/>
        <GradientStop Color="{StaticResource CanvasColor}" Offset="1.0"/>
    </RadialGradientBrush>

</ResourceDictionary>
