<UserControl x:Class="Vozcribe.Views.TrayPopup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="320"
             FontFamily="{StaticResource BodyFont}">

    <Border Background="{StaticResource CanvasBrush}" CornerRadius="14" Padding="18"
            BorderBrush="{StaticResource EdgeBrush}" BorderThickness="1"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" Opacity="0.55" ShadowDepth="6" Color="Black"/>
        </Border.Effect>

        <StackPanel>

            <!-- Brand + status -->
            <Grid Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Rectangle Width="3" Height="14" Fill="{StaticResource AmberBrush}" Margin="0,0,8,0"/>
                    <TextBlock Text="VOZCRIBE" FontFamily="{StaticResource MonoFont}"
                               FontSize="10" Foreground="{StaticResource InkBrush}"
                               Typography.Capitals="AllSmallCaps" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="6" Height="6" Fill="{StaticResource TealBrush}" Margin="0,0,7,0"/>
                    <TextBlock Text="{Binding StatusText}" Style="{StaticResource MonoCaption}"
                               Foreground="{StaticResource InkBrush}"/>
                </StackPanel>
            </Grid>

            <!-- MODEL -->
            <TextBlock Style="{StaticResource EyebrowLabel}" Text="MODEL" Margin="0,0,0,6"/>
            <ComboBox ItemsSource="{Binding AllTiers}"
                      SelectedItem="{Binding CurrentTier, Mode=OneWay}"
                      DisplayMemberPath="DisplayName"
                      SelectionChanged="ModelComboBox_SelectionChanged"
                      Style="{StaticResource StudioComboBox}"
                      Margin="0,0,0,16"/>

            <!-- CREDITS — segmented bar + numeric readout -->
            <Grid Margin="0,0,0,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Style="{StaticResource EyebrowLabel}" Text="CREDITS"/>
                    <TextBlock Grid.Column="1" Text="{Binding CreditsDisplay}"
                               FontFamily="{StaticResource MonoFont}" FontSize="11"
                               Foreground="{StaticResource InkBrush}"/>
                </Grid>
                <ProgressBar Grid.Row="1" Value="{Binding CreditsProgress, Mode=OneWay}" Maximum="1"
                             Style="{StaticResource StudioProgressBar}" Margin="0,0,0,4"/>
                <!-- Mixer tick marks -->
                <Grid Grid.Row="2" Height="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
                        <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
                        <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Rectangle Grid.Column="0" Width="1" Height="3" HorizontalAlignment="Left"
                               Fill="{StaticResource EdgeBrush}"/>
                    <Rectangle Grid.Column="1" Width="1" Height="3" HorizontalAlignment="Left"
                               Fill="{StaticResource EdgeBrush}"/>
                    <Rectangle Grid.Column="2" Width="1" Height="3" HorizontalAlignment="Left"
                               Fill="{StaticResource EdgeBrush}"/>
                    <Rectangle Grid.Column="3" Width="1" Height="3" HorizontalAlignment="Left"
                               Fill="{StaticResource EdgeBrush}"/>
                    <Rectangle Grid.Column="4" Width="1" Height="3" HorizontalAlignment="Left"
                               Fill="{StaticResource EdgeBrush}"/>
                    <Rectangle Grid.Column="5" Width="1" Height="3" HorizontalAlignment="Left"
                               Fill="{StaticResource EdgeBrush}"/>
                    <Rectangle Grid.Column="6" Width="1" Height="3" HorizontalAlignment="Left"
                               Fill="{StaticResource EdgeBrush}"/>
                    <Rectangle Grid.Column="7" Width="1" Height="3" HorizontalAlignment="Left"
                               Fill="{StaticResource EdgeBrush}"/>
                    <Rectangle Grid.Column="8" Width="1" Height="3" HorizontalAlignment="Left"
                               Fill="{StaticResource EdgeBrush}"/>
                    <Rectangle Grid.Column="9" Width="1" Height="3" HorizontalAlignment="Right"
                               Fill="{StaticResource EdgeBrush}"/>
                </Grid>
            </Grid>

            <!-- HOTKEY — keycap display -->
            <TextBlock Style="{StaticResource EyebrowLabel}" Text="HOTKEY" Margin="0,0,0,6"/>
            <Border Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource EdgeBrush}" BorderThickness="1"
                    CornerRadius="{StaticResource RadiusMd}" Padding="12,8" Margin="0,0,0,16">
                <TextBlock Text="{Binding HotkeyDisplay}"
                           FontFamily="{StaticResource MonoFont}" FontSize="12"
                           Foreground="{StaticResource InkBrush}"/>
            </Border>

            <!-- PENDING -->
            <StackPanel Visibility="{Binding HasPending, Converter={StaticResource BoolToVis}}"
                        Margin="0,0,0,16">
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Style="{StaticResource EyebrowLabel}" Text="PENDING"/>
                    <TextBlock Grid.Column="1" FontFamily="{StaticResource MonoFont}" FontSize="10"
                               Foreground="{StaticResource AmberBrush}">
                        <Run Text="{Binding PendingCount, Mode=OneWay}"/>
                        <Run Text=" queued"/>
                    </TextBlock>
                </Grid>
                <ItemsControl ItemsSource="{Binding PendingItems}" MaxHeight="120">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource PanelBrush}"
                                    BorderBrush="{StaticResource EdgeSoftBrush}" BorderThickness="1"
                                    CornerRadius="{StaticResource RadiusSm}"
                                    Padding="10,6" Margin="0,0,0,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Error}"
                                               Foreground="{StaticResource InkMutedBrush}"
                                               FontFamily="{StaticResource BodyFont}" FontSize="11"
                                               MaxWidth="190" TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Content="Retry" Click="RetryPending_Click"
                                            Tag="{Binding}" Style="{StaticResource GhostButton}"
                                            FontSize="11" Padding="8,3" Margin="8,0,0,0"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <Rectangle Height="1" Fill="{StaticResource EdgeSoftBrush}" Margin="0,0,0,12"/>

            <!-- Actions -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Settings" Click="Settings_Click"
                        Style="{StaticResource GhostButton}" Margin="0,0,6,0"
                        Padding="12,6" FontSize="12"/>
                <Button Content="Quit" Click="Quit_Click"
                        Style="{StaticResource QuietButton}"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
