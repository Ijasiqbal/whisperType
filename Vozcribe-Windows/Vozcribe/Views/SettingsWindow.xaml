<Window x:Class="Vozcribe.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Vozcribe Settings"
        Width="720" Height="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource CanvasGlow}"
        FontFamily="{StaticResource BodyFont}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════ LEFT RAIL ═══════ -->
        <Border Grid.Column="0" Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource EdgeSoftBrush}" BorderThickness="0,0,1,0">
            <Grid>
                <StackPanel Margin="24,28,0,0" VerticalAlignment="Top">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Rectangle Width="3" Height="18" Fill="{StaticResource AmberBrush}" Margin="0,0,8,0"/>
                        <TextBlock Text="VOZCRIBE" FontFamily="{StaticResource MonoFont}"
                                   FontSize="11" Foreground="{StaticResource InkBrush}"
                                   Typography.Capitals="AllSmallCaps" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Settings" Style="{StaticResource DisplayHeading}"
                               FontSize="28" Margin="0,6,0,32"/>

                    <TextBlock Style="{StaticResource EyebrowLabel}" Text="SECTIONS" Margin="0,0,0,14"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <Rectangle Width="2" Height="14" Fill="{StaticResource AmberBrush}" Margin="0,0,10,0"/>
                        <TextBlock Text="Shortcuts" Style="{StaticResource SectionLabel}"
                                   Foreground="{StaticResource InkBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Transcription" Style="{StaticResource SectionLabel}" Margin="12,0,0,14"/>
                    <TextBlock Text="General" Style="{StaticResource SectionLabel}" Margin="12,0,0,14"/>
                    <TextBlock Text="Account" Style="{StaticResource SectionLabel}" Margin="12,0,0,0"/>
                </StackPanel>

                <TextBlock Margin="24,0,24,24" VerticalAlignment="Bottom"
                           Style="{StaticResource MonoCaption}"
                           Text="v0.1 · studio console"/>
            </Grid>
        </Border>

        <!-- ═══════ CONTENT ═══════ -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <ScrollViewer.Resources>
                <Style TargetType="ScrollBar" BasedOn="{StaticResource StudioScrollBar}"/>
            </ScrollViewer.Resources>
            <StackPanel Margin="48,36,48,36">

                <!-- SHORTCUTS -->
                <TextBlock Style="{StaticResource SectionLabel}" Text="Shortcuts"
                           FontSize="20" Margin="0,0,0,4"/>
                <TextBlock Style="{StaticResource MonoCaption}" Text="HOTKEY &amp; INSERTION MODE"
                           Margin="0,0,0,20"/>

                <TextBlock Style="{StaticResource EyebrowLabel}" Text="HOTKEY" Margin="0,0,0,8"/>
                <ComboBox ItemsSource="{Binding HotkeyPresets}" SelectedItem="{Binding SelectedHotkey}"
                          DisplayMemberPath="DisplayName" Style="{StaticResource StudioComboBox}"
                          HorizontalAlignment="Left" Width="280" Margin="0,0,0,10"/>
                <Button Content="{Binding CaptureHotkeyText}" Click="CaptureHotkey_Click"
                        KeyDown="CaptureHotkey_KeyDown" Style="{StaticResource GhostButton}"
                        HorizontalAlignment="Left" Margin="0,0,0,26"/>

                <TextBlock Style="{StaticResource EyebrowLabel}" Text="TEXT INSERTION" Margin="0,0,0,10"/>
                <RadioButton Content="Paste where I started recording"
                             IsChecked="{Binding IsWhereStarted}"
                             Style="{StaticResource StudioRadioButton}"
                             GroupName="InsertionMode" Margin="0,0,0,8"/>
                <RadioButton Content="Paste in currently active field"
                             IsChecked="{Binding IsWhereCurrent}"
                             Style="{StaticResource StudioRadioButton}"
                             GroupName="InsertionMode" Margin="0,0,0,32"/>

                <Rectangle Height="1" Fill="{StaticResource EdgeSoftBrush}" Margin="0,0,0,32"/>

                <!-- TRANSCRIPTION -->
                <TextBlock Style="{StaticResource SectionLabel}" Text="Transcription"
                           FontSize="20" Margin="0,0,0,4"/>
                <TextBlock Style="{StaticResource MonoCaption}" Text="MODEL TIER"
                           Margin="0,0,0,20"/>

                <TextBlock Style="{StaticResource EyebrowLabel}" Text="MODEL" Margin="0,0,0,8"/>
                <ComboBox ItemsSource="{Binding ModelTiers}" SelectedItem="{Binding SelectedModelTier}"
                          DisplayMemberPath="DisplayName" Style="{StaticResource StudioComboBox}"
                          HorizontalAlignment="Left" Width="280" Margin="0,0,0,32"/>

                <Rectangle Height="1" Fill="{StaticResource EdgeSoftBrush}" Margin="0,0,0,32"/>

                <!-- GENERAL -->
                <TextBlock Style="{StaticResource SectionLabel}" Text="General"
                           FontSize="20" Margin="0,0,0,4"/>
                <TextBlock Style="{StaticResource MonoCaption}" Text="STARTUP &amp; OVERLAY"
                           Margin="0,0,0,20"/>

                <CheckBox Content="Launch at startup" IsChecked="{Binding LaunchAtStartup}"
                          Style="{StaticResource StudioCheckBox}" Margin="0,0,0,16"/>
                <Button Content="Reset Overlay Position" Click="ResetOverlay_Click"
                        Style="{StaticResource GhostButton}" HorizontalAlignment="Left"
                        Margin="0,0,0,32"/>

                <Rectangle Height="1" Fill="{StaticResource EdgeSoftBrush}" Margin="0,0,0,32"/>

                <!-- ACCOUNT -->
                <TextBlock Style="{StaticResource SectionLabel}" Text="Account"
                           FontSize="20" Margin="0,0,0,4"/>
                <TextBlock Style="{StaticResource MonoCaption}" Text="SIGNED IN AS"
                           Margin="0,0,0,14"/>

                <Border Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource EdgeBrush}" BorderThickness="1"
                        CornerRadius="{StaticResource RadiusMd}" Padding="14,10"
                        HorizontalAlignment="Left" Margin="0,0,0,14">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="6" Height="6" Fill="{StaticResource TealBrush}"
                                 VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="{Binding UserEmail}" Style="{StaticResource BodyText}"/>
                    </StackPanel>
                </Border>
                <Button Content="Sign Out" Click="SignOut_Click" Style="{StaticResource GhostButton}"
                        HorizontalAlignment="Left"
                        Visibility="{Binding IsSignedIn, Converter={StaticResource BoolToVis}}"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
