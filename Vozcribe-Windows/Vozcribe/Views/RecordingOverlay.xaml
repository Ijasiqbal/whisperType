<Window x:Class="Vozcribe.Views.RecordingOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Vozcribe"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowActivated="False"
        ShowInTaskbar="False"
        Focusable="False"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseLeftButtonUp="Window_MouseLeftButtonUp">

    <!-- outer shadow wrapper so the glow isn't clipped -->
    <Grid Margin="24">
        <Border x:Name="Shell" MinWidth="260" MinHeight="54"
                CornerRadius="14" Padding="14,10"
                Background="#F20B0B0F"
                BorderBrush="{Binding Orchestrator.CurrentTier.GlowBrush}"
                BorderThickness="1"
                SnapsToDevicePixels="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="32" Opacity="0.55" ShadowDepth="8" Color="Black"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                <!-- ═══════ RECORDING ═══════ -->
                <StackPanel Orientation="Horizontal"
                            Visibility="{Binding IsRecording, Converter={StaticResource BoolToVis}}">

                    <!-- Status dot with breathing glow — tinted to current tier color -->
                    <Grid Width="12" Height="12" Margin="2,0,12,0" VerticalAlignment="Center">
                        <Ellipse Width="22" Height="22" Fill="{Binding Orchestrator.CurrentTier.GlowBrush}">
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="0.9" To="0.15" Duration="0:0:1.1"
                                                             AutoReverse="True">
                                                <DoubleAnimation.EasingFunction>
                                                    <SineEase EasingMode="EaseInOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                        <Ellipse Width="10" Height="10" Fill="{Binding Orchestrator.CurrentTier.ColorBrush}"/>
                    </Grid>

                    <!-- Waveform — 8 bars tinted to current tier color -->
                    <Grid VerticalAlignment="Center" Margin="0,0,14,0" Height="22" Width="74">
                        <Grid.Resources>
                            <Style TargetType="Rectangle">
                                <Setter Property="Width" Value="3"/>
                                <Setter Property="RadiusX" Value="1.5"/>
                                <Setter Property="RadiusY" Value="1.5"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="2,0"/>
                            </Style>
                        </Grid.Resources>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Rectangle Fill="{Binding Orchestrator.CurrentTier.ColorBrush}" Height="{Binding AmplitudeBars[0], Converter={StaticResource AmpToHeight}}"/>
                            <Rectangle Fill="{Binding Orchestrator.CurrentTier.ColorBrush}" Height="{Binding AmplitudeBars[1], Converter={StaticResource AmpToHeight}}"/>
                            <Rectangle Fill="{Binding Orchestrator.CurrentTier.ColorBrush}" Height="{Binding AmplitudeBars[2], Converter={StaticResource AmpToHeight}}"/>
                            <Rectangle Fill="{Binding Orchestrator.CurrentTier.ColorBrush}" Height="{Binding AmplitudeBars[3], Converter={StaticResource AmpToHeight}}"/>
                            <Rectangle Fill="{Binding Orchestrator.CurrentTier.ColorBrush}" Height="{Binding AmplitudeBars[4], Converter={StaticResource AmpToHeight}}"/>
                            <Rectangle Fill="{Binding Orchestrator.CurrentTier.ColorBrush}" Height="{Binding AmplitudeBars[5], Converter={StaticResource AmpToHeight}}"/>
                            <Rectangle Fill="{Binding Orchestrator.CurrentTier.ColorBrush}" Height="{Binding AmplitudeBars[6], Converter={StaticResource AmpToHeight}}"/>
                            <Rectangle Fill="{Binding Orchestrator.CurrentTier.ColorBrush}" Height="{Binding AmplitudeBars[7], Converter={StaticResource AmpToHeight}}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Timer — mono caption -->
                    <TextBlock Text="{Binding DurationText}"
                               FontFamily="{StaticResource MonoFont}" FontSize="13"
                               Foreground="{StaticResource InkBrush}"
                               VerticalAlignment="Center" Margin="0,0,14,0"/>

                    <!-- Tier chip — bordered with current tier color -->
                    <Border Background="{StaticResource PanelRaisedBrush}"
                            BorderBrush="{Binding Orchestrator.CurrentTier.ColorBrush}"
                            BorderThickness="1" CornerRadius="4" Padding="7,3"
                            VerticalAlignment="Center" SnapsToDevicePixels="True">
                        <TextBlock Text="{Binding Orchestrator.CurrentTier.ShortName}"
                                   FontFamily="{StaticResource MonoFont}" FontSize="10"
                                   Foreground="{Binding Orchestrator.CurrentTier.ColorBrush}"
                                   Typography.Capitals="AllSmallCaps"/>
                    </Border>
                </StackPanel>

                <!-- ═══════ PROCESSING ═══════ -->
                <StackPanel Orientation="Horizontal"
                            Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}">
                    <!-- Rotating arc — tinted to current tier color -->
                    <Grid Width="14" Height="14" Margin="2,0,12,0" VerticalAlignment="Center">
                        <Path Stroke="{Binding Orchestrator.CurrentTier.ColorBrush}" StrokeThickness="1.6"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Data="M 7 0.5 A 6.5 6.5 0 0 1 13.5 7" RenderTransformOrigin="0.5,0.5">
                            <Path.RenderTransform>
                                <RotateTransform x:Name="SpinnerRotate" Angle="0"/>
                            </Path.RenderTransform>
                            <Path.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetName="SpinnerRotate"
                                                             Storyboard.TargetProperty="Angle"
                                                             From="0" To="360" Duration="0:0:0.9"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Path.Triggers>
                        </Path>
                    </Grid>
                    <TextBlock Text="Transcribing"
                               FontFamily="{StaticResource DisplayFont}" FontStyle="Italic" FontSize="16"
                               Foreground="{StaticResource InkBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="…" FontFamily="{StaticResource DisplayFont}" FontStyle="Italic" FontSize="16"
                               Foreground="{Binding Orchestrator.CurrentTier.ColorBrush}" VerticalAlignment="Center" Margin="2,0,0,0"/>
                </StackPanel>

                <!-- ═══════ SUCCESS ═══════ -->
                <StackPanel Visibility="{Binding IsSuccess, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <Grid Width="16" Height="16" Margin="0,0,10,0" VerticalAlignment="Center">
                            <Ellipse Fill="#224FB8A8"/>
                            <Path Data="M 4 8 L 7 11 L 12 5" Stroke="{StaticResource TealBrush}"
                                  StrokeThickness="1.6" StrokeLineJoin="Round"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        </Grid>
                        <TextBlock Text="{Binding Orchestrator.State.Text}"
                                   FontFamily="{StaticResource BodyFont}" FontSize="13"
                                   Foreground="{StaticResource InkBrush}"
                                   MaxWidth="280" TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Content="Copy" Click="CopyButton_Click"
                            Visibility="{Binding ShowCopyButton, Converter={StaticResource BoolToVis}}"
                            Style="{StaticResource GhostButton}" Margin="0,8,0,0"
                            HorizontalAlignment="Left" Padding="12,5" FontSize="12"/>
                </StackPanel>

                <!-- ═══════ ERROR ═══════ -->
                <StackPanel Visibility="{Binding IsError, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Border Background="#22E05D5D" CornerRadius="3" Padding="5,1" Margin="0,0,8,0"
                                VerticalAlignment="Center">
                            <TextBlock Text="ERR" FontFamily="{StaticResource MonoFont}" FontSize="9"
                                       Foreground="{StaticResource RedBrush}"
                                       Typography.Capitals="AllSmallCaps"/>
                        </Border>
                        <TextBlock Text="{Binding Orchestrator.State.Text}"
                                   Foreground="{StaticResource InkBrush}"
                                   FontFamily="{StaticResource BodyFont}" FontSize="12"
                                   MaxWidth="260" TextWrapping="Wrap" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Retry" Click="RetryButton_Click"
                                Style="{StaticResource GhostButton}" Margin="0,0,6,0"
                                Padding="12,5" FontSize="12"/>
                        <Button x:Name="RetryWithButton" Click="RetryWithButton_Click"
                                Style="{StaticResource QuietButton}" Margin="0,0,6,0"
                                Padding="10,5" FontSize="12">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding LastFailedTier.ShortName, FallbackValue=Model}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text=" ▾" VerticalAlignment="Center" FontSize="10"/>
                            </StackPanel>
                            <Button.ContextMenu>
                                <ContextMenu x:Name="RetryWithMenu"
                                             ItemsSource="{Binding AllTiers}">
                                    <ContextMenu.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayName}"/>
                                        </DataTemplate>
                                    </ContextMenu.ItemTemplate>
                                    <ContextMenu.ItemContainerStyle>
                                        <Style TargetType="MenuItem">
                                            <EventSetter Event="Click" Handler="RetryWithTier_Click"/>
                                        </Style>
                                    </ContextMenu.ItemContainerStyle>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                        <Button Content="Save for later" Click="SaveButton_Click"
                                Style="{StaticResource QuietButton}"/>
                    </StackPanel>
                </StackPanel>
                </Grid>

                <Button Grid.Column="1" Style="{StaticResource CloseIconButton}"
                        Click="CloseButton_Click"
                        ToolTip="Dismiss (Esc)"
                        Margin="10,0,0,0"
                        VerticalAlignment="Top"/>
            </Grid>
        </Border>
    </Grid>
</Window>
