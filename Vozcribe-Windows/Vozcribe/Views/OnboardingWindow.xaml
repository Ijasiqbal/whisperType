<Window x:Class="Vozcribe.Views.OnboardingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Welcome to Vozcribe"
        Width="860" Height="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        Background="{StaticResource CanvasGlow}"
        FontFamily="{StaticResource BodyFont}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════ LEFT RAIL ═══════ -->
        <Border Grid.Column="0" Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource EdgeSoftBrush}" BorderThickness="0,0,1,0">
            <Grid>
                <!-- Brand mark top -->
                <StackPanel Margin="28,32,0,0" VerticalAlignment="Top">
                    <StackPanel Orientation="Horizontal">
                        <Rectangle Width="3" Height="18" Fill="{StaticResource AmberBrush}" Margin="0,0,8,0"/>
                        <TextBlock Text="VOZCRIBE" FontFamily="{StaticResource MonoFont}"
                                   FontSize="11" Foreground="{StaticResource InkBrush}"
                                   Typography.Capitals="AllSmallCaps" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <!-- Step indicator -->
                <StackPanel Margin="28,0,28,0" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource EyebrowLabel}" Text="SETUP" Margin="0,0,0,20"/>

                    <StackPanel x:Name="StepRow1" Orientation="Horizontal" Margin="0,0,0,22">
                        <TextBlock Text="01" FontFamily="{StaticResource MonoFont}" FontSize="11"
                                   Foreground="{StaticResource AmberBrush}" VerticalAlignment="Center"
                                   Margin="0,0,14,0"/>
                        <TextBlock Text="Identity" Style="{StaticResource SectionLabel}"
                                   Foreground="{StaticResource InkBrush}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel x:Name="StepRow2" Orientation="Horizontal" Margin="0,0,0,22">
                        <TextBlock Text="02" FontFamily="{StaticResource MonoFont}" FontSize="11"
                                   Foreground="{StaticResource InkDimBrush}" VerticalAlignment="Center"
                                   Margin="0,0,14,0"/>
                        <TextBlock Text="Microphone" Style="{StaticResource SectionLabel}"
                                   Foreground="{StaticResource InkDimBrush}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel x:Name="StepRow3" Orientation="Horizontal" Margin="0,0,0,22">
                        <TextBlock Text="03" FontFamily="{StaticResource MonoFont}" FontSize="11"
                                   Foreground="{StaticResource InkDimBrush}" VerticalAlignment="Center"
                                   Margin="0,0,14,0"/>
                        <TextBlock Text="Shortcut" Style="{StaticResource SectionLabel}"
                                   Foreground="{StaticResource InkDimBrush}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel x:Name="StepRow4" Orientation="Horizontal">
                        <TextBlock Text="04" FontFamily="{StaticResource MonoFont}" FontSize="11"
                                   Foreground="{StaticResource InkDimBrush}" VerticalAlignment="Center"
                                   Margin="0,0,14,0"/>
                        <TextBlock Text="Find me" Style="{StaticResource SectionLabel}"
                                   Foreground="{StaticResource InkDimBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <!-- Footer note -->
                <TextBlock Margin="28,0,28,28" VerticalAlignment="Bottom"
                           Style="{StaticResource MonoCaption}"
                           Text="Voice to text,&#x0a;everywhere you type."/>
            </Grid>
        </Border>

        <!-- ═══════ RIGHT CONTENT ═══════ -->
        <Grid Grid.Column="1" Margin="56,0">

            <!-- Step 1: Sign in -->
            <StackPanel x:Name="Step1" VerticalAlignment="Center" MaxWidth="380" HorizontalAlignment="Left">
                <TextBlock Style="{StaticResource EyebrowLabel}" Text="STEP ONE" Margin="0,0,0,18"/>
                <TextBlock Style="{StaticResource DisplayHeading}" Margin="0,0,0,6">
                    <Run Text="Welcome,"/>
                    <LineBreak/>
                    <Run Text="let's get you" Foreground="{StaticResource InkMutedBrush}"/>
                    <Run Text=" signed in." Foreground="{StaticResource AmberBrush}"/>
                </TextBlock>
                <TextBlock Style="{StaticResource MutedText}" Margin="0,18,0,32"
                           TextWrapping="Wrap">
                    Vozcribe syncs your preferences and credits across devices. One account, everywhere.
                </TextBlock>

                <Button Content="Continue with Google" Click="SignIn_Click"
                        HorizontalAlignment="Left" Style="{StaticResource PrimaryButton}"
                        IsEnabled="{Binding IsNotSigningIn}"/>

                <TextBlock Text="{Binding SignInError}" Foreground="{StaticResource RedBrush}"
                           FontFamily="{StaticResource BodyFont}" FontSize="12" Margin="0,16,0,0"
                           TextWrapping="Wrap"
                           Visibility="{Binding HasSignInError, Converter={StaticResource BoolToVis}}"/>
            </StackPanel>

            <!-- Step 2: Mic -->
            <StackPanel x:Name="Step2" VerticalAlignment="Center" MaxWidth="380" HorizontalAlignment="Left"
                        Visibility="Collapsed">
                <TextBlock Style="{StaticResource EyebrowLabel}" Text="STEP TWO" Margin="0,0,0,18"/>
                <TextBlock Style="{StaticResource DisplayHeading}" Margin="0,0,0,6">
                    <Run Text="Can you"/>
                    <LineBreak/>
                    <Run Text="hear me" Foreground="{StaticResource InkMutedBrush}"/>
                    <Run Text=" now?" Foreground="{StaticResource AmberBrush}"/>
                </TextBlock>
                <TextBlock Style="{StaticResource MutedText}" Margin="0,18,0,28" TextWrapping="Wrap">
                    Vozcribe listens only while your shortcut is held. Nothing streams in the background.
                </TextBlock>

                <Border Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource EdgeBrush}" BorderThickness="1"
                        CornerRadius="{StaticResource RadiusMd}" Padding="16,12" Margin="0,0,0,28">
                    <TextBlock x:Name="MicStatus" FontFamily="{StaticResource BodyFont}" FontSize="13"/>
                </Border>

                <Button Content="Continue" Click="MicNext_Click"
                        HorizontalAlignment="Left" Style="{StaticResource PrimaryButton}"/>
            </StackPanel>

            <!-- Step 3: Hotkey -->
            <StackPanel x:Name="Step3" VerticalAlignment="Center" MaxWidth="420" HorizontalAlignment="Left"
                        Visibility="Collapsed">
                <TextBlock Style="{StaticResource EyebrowLabel}" Text="STEP THREE" Margin="0,0,0,18"/>
                <TextBlock Style="{StaticResource DisplayHeading}" Margin="0,0,0,6">
                    <Run Text="Pick your"/>
                    <LineBreak/>
                    <Run Text="trigger." Foreground="{StaticResource AmberBrush}"/>
                </TextBlock>
                <TextBlock Style="{StaticResource MutedText}" Margin="0,18,0,24" TextWrapping="Wrap">
                    Press and hold to record. Release to transcribe. You can change this any time.
                </TextBlock>

                <TextBlock Style="{StaticResource EyebrowLabel}" Text="SHORTCUT" Margin="0,0,0,8"/>
                <ComboBox ItemsSource="{Binding HotkeyPresets}" DisplayMemberPath="DisplayName"
                          SelectionChanged="Hotkey_SelectionChanged" SelectedIndex="0"
                          HorizontalAlignment="Left" Width="260"
                          Style="{StaticResource StudioComboBox}" Margin="0,0,0,32"/>

                <Button Content="Continue" Click="HotkeyNext_Click"
                        HorizontalAlignment="Left" Style="{StaticResource PrimaryButton}"/>
            </StackPanel>
            <!-- Step 4: Find in tray -->
            <ScrollViewer x:Name="Step4" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled" Visibility="Collapsed">
                <StackPanel Margin="0,36,0,28">

                    <TextBlock Style="{StaticResource EyebrowLabel}" Text="STEP FOUR" Margin="0,0,0,16"/>

                    <TextBlock Style="{StaticResource DisplayHeading}" FontSize="34" LineHeight="38" Margin="0,0,0,6">
                        <Run Text="One last thing —"/>
                        <LineBreak/>
                        <Run Text="I live down here in your " Foreground="{StaticResource InkMutedBrush}"/>
                        <Run Text="tray." Foreground="{StaticResource AmberBrush}"/>
                    </TextBlock>

                    <TextBlock FontFamily="{StaticResource BodyFont}" FontSize="13"
                               Foreground="{StaticResource InkMutedBrush}"
                               LineHeight="20" Margin="0,0,0,20" TextWrapping="Wrap">
                        <Run Text="When this window closes, Vozcribe runs quietly in the background. Find "/>
                        <Run Text="status, model, credits, and your hotkey"
                             Foreground="{StaticResource InkBrush}" FontWeight="SemiBold"/>
                        <Run Text=" by clicking the amber tile near your clock."/>
                    </TextBlock>

                    <TextBlock Style="{StaticResource EyebrowLabel}" Text="YOUR TASKBAR" Margin="0,0,0,8"/>

                    <!-- Stage: outer Grid holds clipped desktop + callout overlay -->
                    <Grid Margin="0,0,0,14">
                        <!-- Clipped desktop mockup -->
                        <Border Height="158" CornerRadius="8" ClipToBounds="True">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0.1,0" EndPoint="0.9,1">
                                    <GradientStop Color="#FF1a2030" Offset="0"/>
                                    <GradientStop Color="#FF14181f" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.BorderBrush><StaticResource ResourceKey="EdgeBrush"/></Border.BorderBrush>
                            <Border.BorderThickness>1</Border.BorderThickness>
                            <Grid>
                                <!-- Desktop icons top-left -->
                                <StackPanel VerticalAlignment="Top" HorizontalAlignment="Left"
                                            Margin="14,12,0,0" Opacity="0.6">
                                    <StackPanel HorizontalAlignment="Center" Margin="0,0,0,10">
                                        <Rectangle Width="22" Height="22" Fill="#CCF2EEE5" RadiusX="3" RadiusY="3"/>
                                        <TextBlock Text="Documents" FontSize="7.5" Foreground="#CCF2EEE5"
                                                   HorizontalAlignment="Center" Margin="0,2,0,0"
                                                   FontFamily="{StaticResource BodyFont}"/>
                                    </StackPanel>
                                    <StackPanel HorizontalAlignment="Center" Margin="0,0,0,10">
                                        <Rectangle Width="22" Height="22" Fill="#CC4FB8A8" RadiusX="3" RadiusY="3"/>
                                        <TextBlock Text="Recordings" FontSize="7.5" Foreground="#CCF2EEE5"
                                                   HorizontalAlignment="Center" Margin="0,2,0,0"
                                                   FontFamily="{StaticResource BodyFont}"/>
                                    </StackPanel>
                                    <StackPanel HorizontalAlignment="Center">
                                        <Rectangle Width="22" Height="22" Fill="#CCFFB547" RadiusX="3" RadiusY="3"/>
                                        <TextBlock Text="Vozcribe" FontSize="7.5" Foreground="#CCF2EEE5"
                                                   HorizontalAlignment="Center" Margin="0,2,0,0"
                                                   FontFamily="{StaticResource BodyFont}"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Taskbar bottom -->
                                <Border VerticalAlignment="Bottom" Height="40">
                                    <Border.Background><SolidColorBrush Color="#CC14141A"/></Border.Background>
                                    <Border.BorderBrush><SolidColorBrush Color="#0AFFFFFF"/></Border.BorderBrush>
                                    <Border.BorderThickness>0,1,0,0</Border.BorderThickness>
                                    <Grid>
                                        <!-- Pinned icons centered -->
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                                    Orientation="Horizontal">
                                            <Border Width="24" Height="24" CornerRadius="4" Margin="3,0">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#FF4FB8A8" Offset="0"/>
                                                        <GradientStop Color="#FF2C7A6E" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                            <Rectangle Width="13" Height="13" Fill="#D9F2EEE5" RadiusX="2" RadiusY="2" Margin="3,0"/>
                                            <Rectangle Width="13" Height="13" Fill="#D97888C8" RadiusX="2" RadiusY="2" Margin="3,0"/>
                                            <Rectangle Width="13" Height="13" Fill="#B3B450C8" RadiusX="2" RadiusY="2" Margin="3,0"/>
                                            <Rectangle Width="13" Height="13" Fill="#B350A05A" RadiusX="2" RadiusY="2" Margin="3,0"/>
                                        </StackPanel>
                                        <!-- Tray right -->
                                        <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center"
                                                    Orientation="Horizontal" Margin="0,0,8,0">
                                            <Border Width="20" Height="26" CornerRadius="3" Margin="0,0,3,0">
                                                <TextBlock Text="^" FontFamily="{StaticResource MonoFont}" FontSize="10"
                                                           Foreground="{StaticResource InkMutedBrush}"
                                                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="((" FontFamily="{StaticResource MonoFont}" FontSize="9"
                                                       Foreground="{StaticResource InkDimBrush}"
                                                       VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <!-- Vozcribe amber tray icon -->
                                            <Border Width="26" Height="26" CornerRadius="5"
                                                    Background="{StaticResource AmberBrush}" Margin="0,0,6,0">
                                                <Border.Effect>
                                                    <DropShadowEffect Color="#FFFFB547" BlurRadius="14"
                                                                      ShadowDepth="0" Opacity="0.7"/>
                                                </Border.Effect>
                                                <Viewbox Margin="3">
                                                    <Canvas Width="80" Height="80">
                                                        <Path Data="M14,30 L22,42 L27,30 L32,52 L36,28 L40,60 L44,26 L48,50 L53,30 L58,40 L66,18"
                                                              Stroke="#FF1A1208" StrokeThickness="9"
                                                              StrokeLineJoin="Round" StrokeStartLineCap="Round"
                                                              StrokeEndLineCap="Round"/>
                                                    </Canvas>
                                                </Viewbox>
                                            </Border>
                                            <!-- Clock -->
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="2:14 PM" FontSize="10"
                                                           Foreground="{StaticResource InkBrush}"
                                                           FontFamily="{StaticResource BodyFont}"/>
                                                <TextBlock Text="Apr 29" FontSize="8.5"
                                                           Foreground="{StaticResource InkMutedBrush}"
                                                           FontFamily="{StaticResource BodyFont}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Callout overlay (top-right, outside clip for shadow) -->
                        <Border VerticalAlignment="Top" HorizontalAlignment="Right"
                                Margin="0,10,18,0" Width="188" Padding="11,9" CornerRadius="8">
                            <Border.Background><StaticResource ResourceKey="PanelRaisedBrush"/></Border.Background>
                            <Border.BorderBrush><StaticResource ResourceKey="AmberBrush"/></Border.BorderBrush>
                            <Border.BorderThickness>1</Border.BorderThickness>
                            <Border.Effect>
                                <DropShadowEffect Color="#FFFFB547" BlurRadius="22" ShadowDepth="0" Opacity="0.3"/>
                            </Border.Effect>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <Ellipse Width="5" Height="5" Fill="{StaticResource AmberBrush}"
                                             VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="9.5"
                                               Foreground="{StaticResource AmberBrush}"
                                               Text="THAT'S ME" Typography.Capitals="AllSmallCaps"/>
                                </StackPanel>
                                <TextBlock FontFamily="{StaticResource DisplayFont}" FontStyle="Italic"
                                           FontSize="14" Foreground="{StaticResource InkBrush}"
                                           TextWrapping="Wrap" Margin="0,0,0,4" LineHeight="17">
                                    Click the amber tile to open Vozcribe.
                                </TextBlock>
                                <TextBlock FontFamily="{StaticResource BodyFont}" FontSize="11"
                                           Foreground="{StaticResource InkMutedBrush}"
                                           TextWrapping="Wrap" LineHeight="15">
                                    Or right-click for quick controls. Closing this window doesn't quit the app.
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Info cards row -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Card 1: What you'll see -->
                        <Border Grid.Column="0" BorderBrush="{StaticResource EdgeSoftBrush}" BorderThickness="1"
                                CornerRadius="8" Padding="14" Background="{StaticResource PanelBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="01" FontFamily="{StaticResource MonoFont}"
                                           FontSize="11" Foreground="{StaticResource AmberBrush}"
                                           VerticalAlignment="Top" Margin="0,1,0,0"/>
                                <StackPanel Grid.Column="2">
                                    <TextBlock FontFamily="{StaticResource DisplayFont}" FontStyle="Italic"
                                               FontSize="16" Foreground="{StaticResource InkBrush}"
                                               Margin="0,0,0,4" LineHeight="19">What you'll see</TextBlock>
                                    <TextBlock FontSize="11.5" FontFamily="{StaticResource BodyFont}"
                                               Foreground="{StaticResource InkMutedBrush}"
                                               TextWrapping="Wrap" LineHeight="16">
                                        Click once for status, model, and credits. Right-click for Settings, Check for Update, Report Issue, and Quit.
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Card 2: Don't see the icon? -->
                        <Border Grid.Column="2" BorderBrush="{StaticResource EdgeSoftBrush}" BorderThickness="1"
                                CornerRadius="8" Padding="14" Background="{StaticResource PanelBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="02" FontFamily="{StaticResource MonoFont}"
                                           FontSize="11" Foreground="{StaticResource AmberBrush}"
                                           VerticalAlignment="Top" Margin="0,1,0,0"/>
                                <StackPanel Grid.Column="2">
                                    <TextBlock FontFamily="{StaticResource DisplayFont}" FontStyle="Italic"
                                               FontSize="16" Foreground="{StaticResource InkBrush}"
                                               Margin="0,0,0,4" LineHeight="19">Don't see the icon?</TextBlock>
                                    <TextBlock FontSize="11.5" FontFamily="{StaticResource BodyFont}"
                                               Foreground="{StaticResource InkMutedBrush}"
                                               TextWrapping="Wrap" LineHeight="16">
                                        <Run Text="Click the "/>
                                        <Run FontFamily="{StaticResource MonoFont}" FontSize="10"
                                             Background="#FF0A0A0F" Text="^"/>
                                        <Run Text=" arrow in the tray. New icons start hidden — drag Vozcribe out to pin it."/>
                                    </TextBlock>
                                    <!-- Overflow flyout demo -->
                                    <Border Margin="0,8,0,0" Padding="7" BorderBrush="{StaticResource EdgeBrush}"
                                            BorderThickness="1" CornerRadius="4" Background="#FF0A0A0F">
                                        <StackPanel>
                                            <Border Margin="0,0,0,6" Padding="5"
                                                    BorderBrush="{StaticResource EdgeBrush}" BorderThickness="1"
                                                    CornerRadius="3" Background="{StaticResource PanelRaisedBrush}">
                                                <UniformGrid Columns="3">
                                                    <Border Margin="2" Height="16" Background="{StaticResource PanelBrush}" CornerRadius="2"/>
                                                    <Border Margin="2" Height="16" Background="{StaticResource PanelBrush}" CornerRadius="2"/>
                                                    <!-- Vozcribe icon (amber, highlighted) -->
                                                    <Border Margin="2" Height="16" Background="{StaticResource AmberBrush}" CornerRadius="2">
                                                        <Viewbox Margin="2">
                                                            <Canvas Width="80" Height="80">
                                                                <Path Data="M14,30 L22,42 L27,30 L32,52 L36,28 L40,60 L44,26 L48,50 L53,30 L58,40 L66,18"
                                                                      Stroke="#FF1A1208" StrokeThickness="9"
                                                                      StrokeLineJoin="Round" StrokeStartLineCap="Round"
                                                                      StrokeEndLineCap="Round"/>
                                                            </Canvas>
                                                        </Viewbox>
                                                    </Border>
                                                    <Border Margin="2" Height="16" Background="{StaticResource PanelBrush}" CornerRadius="2"/>
                                                    <Border Margin="2" Height="16" Background="{StaticResource PanelBrush}" CornerRadius="2"/>
                                                    <Border Margin="2" Height="16" Background="{StaticResource PanelBrush}" CornerRadius="2"/>
                                                </UniformGrid>
                                            </Border>
                                            <DockPanel>
                                                <TextBlock DockPanel.Dock="Left" Text="↓" FontSize="13"
                                                           Foreground="{StaticResource AmberBrush}"
                                                           VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right"
                                                            Orientation="Horizontal">
                                                    <Border Padding="3,2" BorderBrush="{StaticResource AmberBrush}"
                                                            BorderThickness="1" CornerRadius="3" Margin="0,0,3,0">
                                                        <TextBlock Text="^" FontFamily="{StaticResource MonoFont}"
                                                                   FontSize="9" Foreground="{StaticResource AmberBrush}"/>
                                                    </Border>
                                                    <Rectangle Width="11" Height="11" Fill="{StaticResource InkDimBrush}"
                                                               RadiusX="2" RadiusY="2" Opacity="0.4" Margin="0,0,3,0"/>
                                                    <Rectangle Width="11" Height="11" Fill="{StaticResource InkDimBrush}"
                                                               RadiusX="2" RadiusY="2" Opacity="0.4"/>
                                                </StackPanel>
                                            </DockPanel>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Footer -->
                    <DockPanel Margin="0,16,0,0" LastChildFill="False">
                        <TextBlock DockPanel.Dock="Right" Text="04 / 04"
                                   FontFamily="{StaticResource MonoFont}" FontSize="10"
                                   Foreground="{StaticResource InkDimBrush}" VerticalAlignment="Center"/>
                        <Button DockPanel.Dock="Left" Content="Got it — Start Using Vozcribe"
                                Click="TrayGotIt_Click" Style="{StaticResource PrimaryButton}"/>
                        <Button DockPanel.Dock="Left" Content="I'll find it myself"
                                Click="TraySkip_Click" Style="{StaticResource GhostButton}"
                                Foreground="{StaticResource InkMutedBrush}" Margin="12,0,0,0"/>
                    </DockPanel>

                </StackPanel>
            </ScrollViewer>

        </Grid>
    </Grid>
</Window>
