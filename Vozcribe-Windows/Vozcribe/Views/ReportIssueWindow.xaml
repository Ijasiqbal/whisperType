<Window x:Class="Vozcribe.Views.ReportIssueWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Report an Issue"
        Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource CanvasGlow}"
        FontFamily="{StaticResource BodyFont}">

    <StackPanel Margin="32,28,32,28">

        <!-- Header -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
            <Rectangle Width="3" Height="14" Fill="{StaticResource AmberBrush}"
                       Margin="0,0,8,0" VerticalAlignment="Center"/>
            <TextBlock Text="VOZCRIBE" Style="{StaticResource EyebrowLabel}"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <TextBlock Text="Report an Issue" Style="{StaticResource DisplayHeading}"
                   FontSize="26" Margin="0,6,0,4"/>
        <TextBlock Text="Describe the problem and we'll look into it"
                   Style="{StaticResource MutedText}" FontSize="12" Margin="0,0,0,24"/>

        <!-- Category -->
        <TextBlock Style="{StaticResource EyebrowLabel}" Text="CATEGORY" Margin="0,0,0,8"/>
        <ComboBox x:Name="CategoryBox" Style="{StaticResource StudioComboBox}"
                  Margin="0,0,0,20" Padding="12,9">
            <ComboBoxItem Content="Bug" Tag="bug" IsSelected="True"/>
            <ComboBoxItem Content="Feature Request" Tag="feature_request"/>
            <ComboBoxItem Content="Transcription Issue" Tag="transcription_issue"/>
            <ComboBoxItem Content="Other" Tag="other"/>
        </ComboBox>

        <!-- Description -->
        <TextBlock Style="{StaticResource EyebrowLabel}" Text="DESCRIPTION" Margin="0,0,0,8"/>
        <TextBox x:Name="DescriptionBox"
                 AcceptsReturn="True" TextWrapping="Wrap"
                 Height="120" Padding="12,10"
                 Background="{StaticResource PanelRaisedBrush}"
                 Foreground="{StaticResource InkBrush}"
                 BorderBrush="{StaticResource EdgeBrush}" BorderThickness="1"
                 CaretBrush="{StaticResource InkBrush}"
                 SelectionBrush="{StaticResource AmberGlowBrush}"
                 VerticalScrollBarVisibility="Auto"
                 Margin="0,0,0,8"/>

        <TextBlock Text="Device info will be attached automatically"
                   Style="{StaticResource MonoCaption}" Margin="0,0,0,24"/>

        <!-- Error message -->
        <TextBlock x:Name="ErrorText"
                   Foreground="{StaticResource RedBrush}"
                   FontFamily="{StaticResource BodyFont}" FontSize="12"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12" Visibility="Collapsed"/>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Click="Cancel_Click"
                    Style="{StaticResource GhostButton}"
                    Padding="16,8" FontSize="13" Margin="0,0,10,0"/>
            <Button x:Name="SubmitButton" Content="Submit"
                    Click="Submit_Click"
                    Style="{StaticResource PrimaryButton}"
                    Padding="20,9" FontSize="13"/>
        </StackPanel>

    </StackPanel>
</Window>
